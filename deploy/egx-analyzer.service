[Unit]
Description=EGX Statistical Analyzer v2
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/egx-analyzer
Environment=EGX_HOST=0.0.0.0
Environment=EGX_PORT=8000
Environment=EGX_SECRET_KEY=replace-this-in-production
Environment=EGX_CORS_ORIGINS=https://your-domain.com
Environment=EGX_DB_PATH=/opt/egx-analyzer/data/egx_v2.db
ExecStart=/usr/local/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
