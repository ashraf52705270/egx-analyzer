# EGX Analyzer - إعدادات البيئة
# ════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك

# السيرفر
EGX_HOST=0.0.0.0
EGX_PORT=8000
EGX_DEBUG=false

# الأمان (غيّر المفتاح في الإنتاج)
EGX_SECRET_KEY=egx-v2-change-this-secret-key-in-production-64bytes!!
EGX_JWT_EXPIRY=24

# CORS - المواقع المسموح لها الاتصال (افصل بينهم بفاصلة)
EGX_CORS_ORIGINS=http://localhost:8000,http://localhost:8780

# قاعدة البيانات
# SQLite (افتراضي):
EGX_DB_PATH=data/egx_v2.db
# PostgreSQL (للإنتاج — يُفعّل تلقائياً لو موجود):
# DATABASE_URL=postgresql://user:pass@localhost:5432/egx_analyzer

# معدل الطلبات المسموح (حد أقصى)
EGX_RATE_LIMIT=60/minute

# إشعارات تليجرام (اختياري — اتركهم فاضيين لو مش عاوز)
EGX_TELEGRAM_BOT_TOKEN=
EGX_TELEGRAM_CHAT_ID=

# إعدادات البيانات
EGX_DATA_TTL=120
EGX_ENGINE_INTERVAL=30
